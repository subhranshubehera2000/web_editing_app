# reel_assembler.py
import sys
from moviepy.editor import (VideoFileClip, concatenate_videoclips, AudioFileClip)
from moviepy.video.fx import all as vfx # For vfx.colorx, vfx.speedx etc.
from moviepy.video.compositing import transitions as transfx
# from moviepy.video.VideoClip import ImageClip # Not directly needed for this fix
import numpy as np
import os
import re 
import traceback
import json # For test in main


def parse_effect_with_value(effect_name_str, default_value_if_not_specified=None):
    match = re.match(r"([A-Za-z]+)_([\d\.]+)(x|%)?", effect_name_str)
    if match:
        name = match.group(1)
        value_str = match.group(2)
        unit = match.group(3)
        try:
            value = float(value_str)
            if unit == '%': return name, value / 100.0
            return name, value
        except ValueError:
            print(f"Warning: Could not parse value for effect '{effect_name_str}'.")
            return name, default_value_if_not_specified
    return effect_name_str, default_value_if_not_specified


def apply_color_grade(clip, style_name):
    """Applies conceptual color grade. Replace with actual LUTs or image processing."""
    print(f"  Applying color grade: '{style_name}' to clip (dur: {clip.duration:.2f}s)")
    if style_name == "VibrantPop":
        return clip.fx(vfx.colorx, 1.3) # Example: increase color saturation
    elif style_name == "CoolCinematic":
        return clip.fx(vfx.lum_contrast, contrast=0.1, lum=-3) # Slight contrast, cooler
    elif style_name == "WarmVintage":
        # Modify RGB channels using fl_image to apply a function to each frame
        def warm_vintage_filter(image_frame):
            # image_frame is a HxWx3 Numpy array (RGB)
            # Make a writable copy
            frame_copy = image_frame.copy()
            # Increase Red, slightly decrease Blue
            frame_copy[:,:,0] = np.clip(frame_copy[:,:,0] * 1.1, 0, 255) # Red
            # frame_copy[:,:,1] = np.clip(frame_copy[:,:,1] * 1.0, 0, 255) # Green (optional slight adjustment)
            frame_copy[:,:,2] = np.clip(frame_copy[:,:,2] * 0.9, 0, 255) # Blue
            return frame_copy.astype(np.uint8)
        
        return clip.fl_image(warm_vintage_filter)
    elif style_name == "MonochromeClassic":
        return clip.fx(vfx.blackwhite)
    elif style_name == "NaturalEnhance":
         return clip.fx(vfx.colorx, 1.1)
    print(f"    Color grade style '{style_name}' not recognized or placeholder. No change.")
    return clip


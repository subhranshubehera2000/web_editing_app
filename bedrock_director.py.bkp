# bedrock_director.py
import boto3
import json
import os
import traceback
import numpy as np
import re # For enhanced JSON extraction

AWS_REGION = "ap-south-1"
MODEL_ID = "anthropic.claude-3-sonnet-20240229-v1:0"
# Consider Haiku for faster/cheaper testing if Sonnet is slow/costly:
# MODEL_ID = "anthropic.claude-3-haiku-20240307-v1:0"

bedrock_runtime = boto3.client(service_name='bedrock-runtime', region_name=AWS_REGION)

def generate_ai_edit_plan(audio_data, all_video_shots_metadata,
                          desired_reel_duration_min_sec, desired_reel_duration_max_sec,
                          reel_theme="general upbeat and engaging"):
    print(f"\n[bedrock_director] Generating AI edit plan with Bedrock model: {MODEL_ID}")

    # Prepare audio features for the prompt, ensure they are lists for clean JSON in prompt
    audio_beat_times_summary = []
    if 'beat_times' in audio_data and isinstance(audio_data['beat_times'], (list, np.ndarray)) and len(audio_data['beat_times']) > 0:
        audio_beat_times_summary = list(np.round(audio_data.get('beat_times', [])[:20], 2))
    
    audio_onset_times_summary = []
    if 'onset_times' in audio_data and isinstance(audio_data['onset_times'], (list, np.ndarray)) and len(audio_data['onset_times']) > 0:
        audio_onset_times_summary = list(np.round(audio_data.get('onset_times', [])[:20], 2))
    
    audio_energy_summary = audio_data.get('simplified_energy_values_at_times', [])[:15] # First 15 energy points

    # ---- Start Prompt Construction ----
    prompt_parts = []
    prompt_parts.append(f"""You are an expert AI video editor. Your task is to create a precise, structured video editing plan based *ONLY* on the provided audio and video shot information.
The output format is *CRITICAL* and MUST be a single JSON object adhering to the specified schema. No other text before or after the JSON.

**Reel Specifications:**
- Theme: "{reel_theme}"
- Target Total Duration: Between {desired_reel_duration_min_sec} and {desired_reel_duration_max_sec} seconds.

**Audio Track Information:**
- Audio Tempo: {audio_data.get('tempo', 'N/A'):.2f} BPM
- Key Beat Times (seconds, first ~20, these are primary sync points): {audio_beat_times_summary}
- Important Audio Onset Times (seconds, first ~20, also good sync points): {audio_onset_times_summary}
- Audio Energy Summary (list of [time_sec, scaled_energy_value_0_to_100+], first ~15 points): {audio_energy_summary}
- Total Audio Duration: {audio_data.get('duration', 'N/A'):.2f} seconds

**Available Video Shots (identified by 'global_shot_id'):**
Each shot has `brightness` (0-255, higher is brighter) and `motion_score` (0-~50+, higher is more motion).
You MUST use the `global_shot_id` from this list to reference video shots in your plan.
Do NOT invent file paths. Do NOT use generic shot names like 'clips/beach_sunset.mp4'.
The `duration_of_this_shot` is the total available length for that specific `global_shot_id`.
""") # End of first major prompt part

    MAX_SHOTS_IN_PROMPT = 70 
    shots_for_prompt = all_video_shots_metadata
    if len(all_video_shots_metadata) > MAX_SHOTS_IN_PROMPT:
        print(f"[bedrock_director] Warning: Number of shots ({len(all_video_shots_metadata)}) exceeds MAX_SHOTS_IN_PROMPT ({MAX_SHOTS_IN_PROMPT}). Sampling shots.")
        # Simple sampling: prioritize shots with higher motion, then brightness
        shots_for_prompt = sorted(all_video_shots_metadata, key=lambda x: (x.get('avg_motion_score', 0), x.get('avg_brightness', 0)), reverse=True)[:MAX_SHOTS_IN_PROMPT]
        print(f"  Using {len(shots_for_prompt)} shots for the prompt after sampling.")


    for i, shot_meta in enumerate(shots_for_prompt):
        prompt_parts.append( # This appends each shot detail as a new string in the list
            f"- global_shot_id: {shot_meta.get('global_shot_id', 'N/A')}, "
            f"source_vid_name_part: {'_'.join(os.path.basename(shot_meta.get('original_video_path', 'N/A')).split('_')[:2])}, " 
            f"duration_of_this_shot: {shot_meta.get('duration_sec', 0):.2f}s, "
            f"brightness: {shot_meta.get('avg_brightness', 0):.0f}, "
            f"motion_score: {shot_meta.get('avg_motion_score', 0):.1f}"
        )

    # ---- CRITICAL: Output Format Definition and EXAMPLE ----
    prompt_parts.append(f"""
**Your Task: Create the JSON Editing Plan**
The output MUST be a SINGLE VALID JSON object. No other text, explanations, or conversational fluff before or after the JSON block.
The JSON object MUST have a root key "edit_plan", which is a list of "segment" objects.
Each "segment" object in the "edit_plan" list MUST have exactly these keys with these data types:
- "global_shot_id": (integer) The `global_shot_id` of the video shot from the "Available Video Shots" list above.
- "segment_start_in_shot_sec": (float) Start time IN SECONDS *within* the chosen `global_shot_id`'s own `duration_of_this_shot`. Must be >= 0.
- "segment_end_in_shot_sec": (float) End time IN SECONDS *within* the chosen `global_shot_id`'s own `duration_of_this_shot`. Must be > `segment_start_in_shot_sec`.
- "color_grade_style": (string) Choose one: "VibrantPop", "CoolCinematic", "NaturalEnhance", "WarmVintage", "MonochromeClassic".
- "transition_to_next": (string) Choose one: "Cut", "Fade", "Dissolve". For the VERY LAST segment, use "None".
- "effects": (list of strings, optional) Examples: "SlowMotion_0.5x", "FastForward_2x", "SlightZoomIn_10%". If none, use an empty list: [].
- "reasoning": (string, brief, max 20 words) E.g., "Matches beat, high energy."

**EXAMPLE of the EXACT desired JSON output format (This is an example, use the actual available global_shot_ids):**
```json
{{
  "edit_plan": [
    {{
      "global_shot_id": 3,
      "segment_start_in_shot_sec": 0.5,
      "segment_end_in_shot_sec": 2.0,
      "color_grade_style": "VibrantPop",
      "transition_to_next": "Cut",
      "effects": ["SlightZoomIn_10%"],
      "reasoning": "Opening shot, matches intro beat."
    }},
    {{
      "global_shot_id": 0,
      "segment_start_in_shot_sec": 1.2,
      "segment_end_in_shot_sec": 3.0,
      "color_grade_style": "NaturalEnhance",
      "transition_to_next": "Fade",
      "effects": [],
      "reasoning": "Calmer visual for bridge section."
    }},
    {{
      "global_shot_id": 5,
      "segment_start_in_shot_sec": 0.0,
      "segment_end_in_shot_sec": 1.5,
      "color_grade_style": "CoolCinematic",
      "transition_to_next": "None",
      "effects": ["SlowMotion_0.5x"],
      "reasoning": "Ending shot, slows with music."
    }}
  ]
}}
Important Instructions for Your Editing Decisions (these are critical for a good plan):

    Rhythm & Pacing (SYNC TO MUSIC!):

        Place cuts ideally ON or very slightly BEFORE (e.g., 0.05s) the beat_times or strong onset_times. These are primary sync points.

        Use the audio_energy_summary (time, energy_value) to guide the "feel":

            Higher energy audio (e.g., energy value > 40-50): Prefer SHORTER segments (0.7s - 1.8s). Use shots with HIGHER motion_score (e.g., > 10-15).

            Lower energy audio (e.g., energy value < 20-30): Can use SLIGHTLY LONGER segments (1.5s - 3.0s), possibly with lower motion_score shots for a calmer feel, if visually engaging.

        Vary segment durations to match the music's dynamic flow. Avoid monotonous, same-length cuts.

    Thematic Relevance & Visual Appeal ("{reel_theme}"):

        Select shots that strongly fit the specified theme. For "{reel_theme}", prioritize dynamic scenery, interesting subjects, clear action, or a sense of exploration/joy.

        Favor shots with good brightness (e.g., > 100-120, unless a dark shot is intentional for mood) and engaging motion_score (e.g., > 5-10 for upbeat).

        Avoid overusing static, low-motion shots (e.g., motion_score < 3) for long durations unless the music is very calm or it's a very brief establishing shot.

        Aim for visual variety. Don't use the same global_shot_id repeatedly for long periods unless for a very specific, short, rhythmic effect.

    Shot Integrity and Duration Calculation (Strict Adherence Required):

        The values for segment_start_in_shot_sec and segment_end_in_shot_sec MUST be within the selected global_shot_id's duration_of_this_shot. Do NOT pick times outside the available range for that shot.

        Effects like "SlowMotion_0.5x" will DOUBLE the segment's contribution to the reel's total duration. "FastForward_2x" will HALVE it. You MUST account for these effects when calculating the total reel duration.

    Transitions & Effects (Enhance, Don't Overwhelm):

        "Cut" is the default and best for maintaining rhythm.

        Use "Fade" or "Dissolve" sparingly, perhaps for significant mood shifts or between less directly related visuals if it helps flow.

        Apply effects like "SlightZoomIn_10%" (a gentle zoom in over the segment's duration) tastefully to add dynamism to relatively static shots if appropriate. Do not overuse effects.

    Total Reel Duration Constraint: The sum of all final segment effective durations (i.e., after any speed-altering effects are applied) MUST be between {desired_reel_duration_min_sec} and {desired_reel_duration_max_sec} seconds. Adhere to this strictly. Check your math.

Begin generating ONLY the JSON object now.
    """)
    # End of the last major prompt part
    # ---- End Prompt Construction ----
if __name__ == '__main__':
    # ALL THE FOLLOWING LINES MUST BE INDENTED
    dummy_audio_data = { # <--- DEFINITION OF dummy_audio_data
        "path": "dummy_audio.mp3", "tempo": 125.0,
        "beat_times": [0.48, 0.96, 1.44, 1.92, 2.4, 2.88, 3.36, 3.84, 4.32, 4.8],
        "onset_times": [0.45, 1.40, 2.35, 3.30, 4.25], "duration": 30.0,
        "simplified_energy_values_at_times": [(0.0, 10.1), (1.0, 35.5), (2.0, 60.2), (5.0, 25.0)]
    }
    dummy_video_shots = [ # <--- DEFINITION OF dummy_video_shots
        {"global_shot_id": 0, "original_video_path": "input_videos/vid_A.mp4", "duration_sec": 5.2, "avg_brightness": 150, "avg_motion_score": 15.5},
        {"global_shot_id": 1, "original_video_path": "input_videos/vid_A.mp4", "duration_sec": 3.0, "avg_brightness": 80, "avg_motion_score": 5.2},
        {"global_shot_id": 5, "original_video_path": "input_videos/vid_B.mp4", "duration_sec": 7.5, "avg_brightness": 180, "avg_motion_score": 25.0},
        {"global_shot_id": 7, "original_video_path": "input_videos/vid_C.mp4", "duration_sec": 4.0, "avg_brightness": 120, "avg_motion_score": 3.1}
    ]
    
    print("\n--- Testing bedrock_director.py with dummy data (will call Bedrock) ---")
    if not os.path.exists("output"): os.makedirs("output")
    edit_plan = generate_ai_edit_plan(dummy_audio_data, dummy_video_shots, 5, 10, reel_theme="Test energetic highlights")
    if edit_plan and "edit_plan" in edit_plan:
        print("\nGenerated Edit Plan (from test):")
        class NpEncoderLocal(json.JSONEncoder): # Define NpEncoder locally for test block
            def default(self, obj):
                if isinstance(obj, np.integer): return int(obj)
                if isinstance(obj, np.floating):
                    if np.isnan(obj): return None # Or str("NaN")
                    if np.isinf(obj): return str(obj) # Or str("Infinity") / None
                    return float(obj)
                if isinstance(obj, np.ndarray): return obj.tolist()
                if isinstance(obj, np.bool_): return bool(obj)
                return super(NpEncoderLocal, self).default(obj)
            print(json.dumps(edit_plan, indent=2, cls=NpEncoderLocal))
            dummy_plan_path = "output/dummy_edit_plan_from_bedrock_test.json"
            try:
                # Use utf-8 encoding when writing files that might contain diverse characters
                with open(dummy_plan_path, "w", encoding="utf-8") as f:
                    json.dump(edit_plan, f, indent=2, cls=NpEncoderLocal)
                    print(f"\nDummy edit plan saved to {dummy_plan_path}")
            except Exception as e_save:
                print(f"Error saving dummy edit plan: {e_save}")
            else:
                print("Failed to generate a valid dummy edit plan structure from Bedrock in test.")
                if edit_plan :
                    print(f"    Bedrock director output was (first 500 chars): {str(edit_plan)[:500]}...")
                else:
                    print("    Bedrock director output was None.")
